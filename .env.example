# OpenAI-Compatible Provider API Settings
# If targeting OpenAI: Use https://api.openai.com/v1 and your OpenAI API key.
# If targeting Ollama: Use http://localhost:11434/v1 and "ollama" (or dummy) for key.
# If targeting LiteLLM: Use your LiteLLM proxy URL and api key.
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL_NAME=gpt-4o-mini

# API Authentication (Token/Key required in headers: X-API-Key: <value>)
# If left blank, security is disabled for local testing.
API_KEY=secret-token-12345

# Server configuration
PORT=8000
HOST=0.0.0.0
